{
  "name": "node-hono",
  "private": true,
  "scripts": {
    "dev:http": "tsnd -r tsconfig-paths/register src/interfaces/http/index.ts",
    "build:http": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start:http": "node dist/interfaces/http/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "dotenv": "^16.6.1",
    "hono": "^4.12.12",
    "hono-pino": "^0.10.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
