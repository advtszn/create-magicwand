{
  "name": "bun-express",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:http": "bun --hot src/interfaces/http/index.ts",
    "build:http": "tsc -p tsconfig.build.json",
    "start:http": "bun --bun dist/interfaces/http/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
