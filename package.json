{
  "name": "create-magicwand",
  "version": "0.0.1",
  "type": "module",
  "description": "🪄 Magicwand — pragmatic DDD backend scaffolding",
  "bin": {
    "create-magicwand": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun build src/cli/index.ts --target node --outfile dist/cli.js --banner '#!/usr/bin/env node'",
    "dev": "bun src/cli/index.ts",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "latest",
    "lefthook": "^2.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
